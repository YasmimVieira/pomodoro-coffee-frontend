{
  "expo": {
    "name": "PomodoroCoffee",
    "slug": "PomodoroCoffee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yvstudio.pomodorocoffee"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#C8894E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.yvstudio.pomodorocoffee"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-splash-screen",
      "expo-build-properties",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2486523735458313~9562089424",
          "iosAppId": "ca-app-pub-2486523735458313~9514291889"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C8894E",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Pomodoro Coffee"
        }
      ],
      "expo-localization"
    ]
  }
}
